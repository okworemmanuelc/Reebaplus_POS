# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# web-pos was moved to the reebaplus_web repo (#104); nothing here should be
# tracked. Ignore any stray regenerated tree (e.g. its Next.js build trace).
/web-pos/

# Claude Code
.claude/

# Environment & secrets
.env
.env.local
.env.production
.env.test
.envrc
# Keys / signing / service accounts (belt-and-suspenders; hooks also enforce these)
*.jks
*.keystore
*.pem
*.p12
*.p8
*.pfx
google-services.json
GoogleService-Info.plist
service-account*.json
Thumbs.db

# Local properties (machine-specific)
android/local.properties

# Supabase CLI local cache
supabase/.temp/

# Debug / analysis output dumps
analyze*.txt
errors.txt
lint_errors.txt
output_lints.txt
flutter_analyze.txt
analysis_*.txt
final_analysis.txt
project_summary*.txt
test.txt
test_checkout.txt

# Agent skills: reproducible dev-time tooling cache. The vendored skill files
# are rebuilt from skills-lock.json (which IS committed), so we track the lock,
# not the cache — the "commit the lockfile, ignore the install" pattern.
.agents/
